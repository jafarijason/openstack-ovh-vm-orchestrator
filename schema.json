  "components": {
    "schemas": {
      "CreateVMRequest": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name",
            "description": "VM name"
          },
          "image_id": {
            "type": "string",
            "title": "Image Id",
            "description": "Image ID to boot from"
          },
          "flavor_id": {
            "type": "string",
            "title": "Flavor Id",
            "description": "Flavor/instance type ID"
          },
          "network_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Network Ids",
            "description": "List of network IDs to attach"
          },
          "key_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Key Name",
            "description": "SSH key name for authentication"
          },
          "security_groups": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Security Groups",
            "description": "Security group names"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata",
            "description": "Custom metadata"
          }
        },
        "type": "object",
        "required": [
          "name",
          "image_id",
          "flavor_id",
          "network_ids"
        ],
        "title": "CreateVMRequest",
        "description": "Request to create a new VM.",
        "example": {
          "flavor_id": "2",
          "image_id": "8a2d8e80-c940-43fa-afa0-d2f8024fcf0a",
          "key_name": "my-key",
          "metadata": {
            "env": "production"
          },
          "name": "my-vm",
          "network_ids": [
            "net-123"
          ],
          "security_groups": [
            "default"
          ]
        }
      },
